<div class="relative w-full h-full">
  <canvas class="map w-full h-full"></canvas>
  <span id="tooltip" class="fixed font-mono font-bold text-sm uppercase text-shadow-sm text-shadow-black"></span>
</div>

<script>
  import debounce from 'debounce'
  import * as THREE from 'three'
  import { OrbitControls } from 'three/addons/controls/OrbitControls.js'
  import { GLTFLoader } from 'three/examples/jsm/Addons.js';
  import { RoomEnvironment } from 'three/addons/environments/RoomEnvironment.js';
  import { EARTH_RADIUS } from '../utils/geojson';

  /*
   * Distance at which the country is on the other side
   * of the globe, or close to it. Distance represents
   * distance from the camera.
   */
  const COUNTRY_HOVER_DISTANCE_FROM_CAMERA = 250

  const COUNTRY_SCALE = 1.06
  const COUNTRY_HOVER_SCALE = 1.09
  const COUNTRY_SCALE_SPEED = new THREE.Vector3(0.004, 0.004, 0.004)

  const SCREEN_WIDTH_LG = 1200

  const canvas = document.querySelector('canvas.map')

  const scene = new THREE.Scene()

  const sizes = {
    width: window.innerWidth,
    height: window.innerHeight,
    pixelRatio: Math.min(window.devicePixelRatio, 2)
  }

  const camera = new THREE.PerspectiveCamera(45, sizes.width / sizes.height, 1, 1000)
  camera.position.set(0, 20, EARTH_RADIUS * 3)

  const controls = new OrbitControls(camera, canvas)
  controls.enableDamping = true
  controls.enableZoom = false
  controls.minPolarAngle=1
  controls.maxPolarAngle=1.8

  scene.add(new THREE.AmbientLight('0xffffff', 0.2))
  const pointLight1 = new THREE.PointLight(0xffffff, 3.0)
  pointLight1.position.set(EARTH_RADIUS * 2, EARTH_RADIUS * 2, EARTH_RADIUS * 2)
  scene.add(pointLight1)
  const pointLight2 = new THREE.PointLight(0x4f46e5, 1.0) /* blue rim light */
  pointLight2.position.set(-200, -100, -100)
  scene.add(pointLight2)

  // Opaque globe
  const globe = new THREE.Mesh(
    new THREE.SphereGeometry(EARTH_RADIUS * 0.99, 64, 64),
    new THREE.MeshBasicMaterial({ color: 0x330000 })
  )
  scene.add(globe)

  // Glossy surface
  const surface = new THREE.Mesh(
    new THREE.SphereGeometry(EARTH_RADIUS, 64, 64),
    // new THREE.MeshBasicMaterial({ color: 'black' })
    new THREE.MeshPhysicalMaterial({
      color: 0x000814,
      roughness: 0.02,
      metalness: 0.3,
      transmission: 0.7,
      thickness: 15,
      clearcoat: 1.0,
      clearcoatRoughness: 0.0,
      ior: 1.5,
      transparent: true,
      opacity: 0.12,
      side: THREE.DoubleSide,
      envMapIntensity: 1.5,
    })
  )
  if (sizes.width >= SCREEN_WIDTH_LG) {
    scene.add(surface)
  }

  // Holographic grid
  const grid = new THREE.Mesh(
    new THREE.SphereGeometry(EARTH_RADIUS * 1.02, 32, 32),
    new THREE.MeshBasicMaterial({
      color: 0xff0000,
      wireframe: true,
      transparent: true,
      opacity: 0.08
    })
  )
  scene.add(grid)

  // Glowing rim (Fresnel Simulation)
  const glow = new THREE.Mesh(
    new THREE.SphereGeometry(EARTH_RADIUS * 1.05, 64, 64),
    new THREE.MeshStandardMaterial({
      color: 0xff0000,
      transparent: true,
      opacity: 0.03,
      side: THREE.DoubleSide,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    })
  )
  scene.add(glow)

  const countryMaterial = new THREE.MeshBasicMaterial({
    color: 0xffbbbb,
    // color: 0x2B3345,
  })
  const countryBGMaterial = new THREE.MeshBasicMaterial({
    visible: false,
  })
  // const countryMaterial = new THREE.MeshPhysicalMaterial({
  //   color: 0x2B3345,
  //   roughness: 0.02,
  //   metalness: 0.3,
  //   transmission: 0.7,
  //   thickness: 15,
  //   clearcoat: 1.0,
  //   clearcoatRoughness: 0.0,
  //   ior: 1.5,
  //   transparent: true,
  //   opacity: 1.0,
  //   envMapIntensity: 1.5,
  //   depthWrite: true,
  // })
  const highlightedCountryMaterial = countryMaterial.clone()
  highlightedCountryMaterial.color.set(0xff8888)
  const selectedCountryMaterial = countryMaterial.clone()
  selectedCountryMaterial.color.set(0xcc3333)
  const borderMaterial = new THREE.LineBasicMaterial({
    color: 0x333333,
    // color: 0x6586b5,
  })
  let countryGroups : THREE.Group[] = []
  let countryIntersectionObjects : THREE.Object3D[] = []
  const gltfLoader = new GLTFLoader()
  gltfLoader.load(
    '/globe-country-boundaries-surface-only.glb',
    gltf => {
      const countryMeshes = [...gltf.scene.children]
      countryMeshes.forEach((mesh: THREE.Object3D) => {
        const group = new THREE.Group()
        group.name = mesh.name
        group.scale.set(
          group.scale.x * COUNTRY_SCALE,
          group.scale.y * COUNTRY_SCALE,
          group.scale.z * COUNTRY_SCALE
        )
        mesh.material = countryMaterial
        mesh.material.shading = THREE.InterpolateSmooth
        mesh.geometry.computeVertexNormals(true)
        group.add(mesh)
        const line = new THREE.LineSegments(
          new THREE.EdgesGeometry(mesh.geometry, 30),
          borderMaterial
        )
        group.add(line)
        scene.add(group)
        countryGroups.push(group)

        // A second country mesh that doesn't move on
        // hover, so that hover targets can be stable.
        // This fixes flashing issue when a hover
        // animation moves the country out from under
        // the mouse position.
        const bgMesh : THREE.Object3D = mesh.clone()
        bgMesh.material = countryBGMaterial
        bgMesh.scale.set(
          bgMesh.scale.x * COUNTRY_SCALE,
          bgMesh.scale.y * COUNTRY_SCALE,
          bgMesh.scale.z * COUNTRY_SCALE
        )
        scene.add(bgMesh)

        countryIntersectionObjects.push(mesh, bgMesh)
      })
    }
  )

  const renderer = new THREE.WebGLRenderer({
    canvas,
    antialias: true,
  })
  renderer.toneMapping = THREE.ACESFilmicToneMapping
  renderer.setSize(sizes.width, sizes.height)
  renderer.setPixelRatio(sizes.pixelRatio)

  const environment = new RoomEnvironment();
  const pmremGenerator = new THREE.PMREMGenerator(renderer);
  scene.background = new THREE.Color( 0x330000 );
  scene.environment = pmremGenerator.fromScene(environment, 0.2).texture;

  const resize = () => {
    sizes.width = window.innerWidth
    sizes.height = window.innerHeight
    sizes.pixelRatio = Math.min(window.devicePixelRatio, 2)

    if (sizes.width >= SCREEN_WIDTH_LG) {
      if (!surface.parent) {
        scene.add(surface)
      }
    } else {
      scene.remove(surface)
    }

    renderer.setSize(sizes.width, sizes.height)
    renderer.setPixelRatio(sizes.pixelRatio)

    camera.aspect = sizes.width / sizes.height
    camera.updateProjectionMatrix()
  }

  window.addEventListener('resize', debounce(resize, 500))

  const TOOLTIP_OFFSET = 16
  const tooltip = document.getElementById('tooltip')

  let hoverEnabled = true

  const mouse = new THREE.Vector2()
  const raycaster = new THREE.Raycaster()
  canvas.addEventListener('mousemove', e => {
    mouse.x = e.clientX / sizes.width * 2 - 1
    mouse.y = - (e.clientY / sizes.height) * 2 + 1
    tooltip.style.top = e.clientY + TOOLTIP_OFFSET + 'px'
    tooltip.style.left = e.clientX + TOOLTIP_OFFSET + 'px'
  })

  // Prevent hover effects on touch devices
  canvas.addEventListener('touchmove', e => {
    hoverEnabled = false
    mouse.x = -10
    mouse.y = -10
  })


  let highlightedGroup : THREE.Group | undefined = undefined
  const highlightGroup = (group?: THREE.Group) => {
    if (highlightedGroup) {
      highlightedGroup.children[0].material = countryMaterial
    }
    if (group) {
      group.children[0].material = highlightedCountryMaterial
    }
    highlightedGroup = group
  }

  let selectedGroup : THREE.Group | undefined = undefined
  const selectGroup = (group?: THREE.Group) => {
    // Second click on group toggles it off
    if (selectedGroup) {
      highlightGroup()
      selectedGroup.children[0].material = countryMaterial
      selectedGroup = undefined
      return
    }
    highlightGroup(group)
    if (group) {
      group.children[0].material = selectedCountryMaterial
    }
    selectedGroup = group
  }

  canvas.addEventListener('click', e => {
    mouse.x = e.clientX / sizes.width * 2 - 1
    mouse.y = - (e.clientY / sizes.height) * 2 + 1
    const countriesFacingCamera = countryIntersectionObjects.filter((mesh: THREE.Object3D) => {
      return mesh.geometry.boundingSphere.distanceToPoint(camera.position) < COUNTRY_HOVER_DISTANCE_FROM_CAMERA
    })
    raycaster.setFromCamera(mouse, camera)
    const intersectedCountries = raycaster.intersectObjects(countriesFacingCamera)
    const group : THREE.Group | undefined = intersectedCountries.length
      ? countryGroups.find(g => g.name === intersectedCountries[0].object.name)
      : undefined
    selectGroup(group)
  })

  const tick = () => {

    // Hover effect
    if (hoverEnabled && countryGroups.length) {
      const countriesFacingCamera = countryIntersectionObjects.filter(mesh => {
        return mesh.geometry.boundingSphere.distanceToPoint(camera.position) < COUNTRY_HOVER_DISTANCE_FROM_CAMERA
      })
      raycaster.setFromCamera(mouse, camera)
      const intersectedCountries = raycaster.intersectObjects(countriesFacingCamera)
      const group : THREE.Group | undefined = intersectedCountries.length
        ? countryGroups.find(g => g.name === intersectedCountries[0].object.name)
        : undefined
      if (tooltip) {
        tooltip.innerHTML = group?.name ?? ''
      }
      if (!selectedGroup) {
        highlightGroup(group)
      }
    }
    if (highlightedGroup && highlightedGroup.scale.x < COUNTRY_HOVER_SCALE) {
      highlightedGroup.scale.add(COUNTRY_SCALE_SPEED)
    }
    countryGroups.forEach(group => {
      if (highlightedGroup && highlightedGroup.name == group.name) {
        return
      }
      if (group.scale.x > COUNTRY_SCALE) {
        group.scale.sub(COUNTRY_SCALE_SPEED)
      }
    })

    controls.update()
    renderer.render(scene, camera)

    window.requestAnimationFrame(tick)
  }

  tick()
</script>