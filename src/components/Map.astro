<canvas class="map w-full h-full"></canvas>

<script>
  import debounce from 'debounce'
  import * as THREE from 'three'
  import { OrbitControls } from 'three/addons/controls/OrbitControls.js'
  import { RoomEnvironment } from 'three/addons/environments/RoomEnvironment.js';
  import { getPositionFromLatLonDepth } from '../utils/geojson'
  import { EARTH_RADIUS } from '../utils/geojson';

  const canvas = document.querySelector('canvas.map')

  const scene = new THREE.Scene()

  const sizes = {
    width: window.innerWidth,
    height: window.innerHeight,
    pixelRatio: Math.min(window.devicePixelRatio, 2)
  }

  const camera = new THREE.PerspectiveCamera(45, sizes.width / sizes.height, 1, 1000)
  camera.position.set(0, 20, EARTH_RADIUS * 3)

  const controls = new OrbitControls(camera, canvas)
  controls.enableDamping = true

  scene.add(new THREE.AmbientLight('0xffffff', 0.2))
  const pointLight1 = new THREE.PointLight(0xffffff, 3.0)
  pointLight1.position.set(EARTH_RADIUS * 2, EARTH_RADIUS * 2, EARTH_RADIUS * 2)
  scene.add(pointLight1)
  const pointLight2 = new THREE.PointLight(0x4f46e5, 1.0) /* blue rim light */
  pointLight2.position.set(-200, -100, -100)
  scene.add(pointLight2)

  // Glossy surface
  const surface = new THREE.Mesh(
    new THREE.SphereGeometry(EARTH_RADIUS, 64, 64),
    // new THREE.MeshBasicMaterial({ color: 'black' })
    new THREE.MeshPhysicalMaterial({
      color: 0x000814,
      roughness: 0.02,
      metalness: 0.3,
      transmission: 0.7,
      thickness: 15,
      clearcoat: 1.0,
      clearcoatRoughness: 0.0,
      ior: 1.5,
      transparent: true,
      opacity: 0.12,
      side: THREE.DoubleSide,
      envMapIntensity: 1.5,
    })
  )
  scene.add(surface)

  // Holographic grid
  const grid = new THREE.Mesh(
    new THREE.SphereGeometry(EARTH_RADIUS * 1.02, 32, 32),
    new THREE.MeshBasicMaterial({
      color: 0x3b82f6,
      wireframe: true,
      transparent: true,
      opacity: 0.08
    })
  )
  scene.add(grid)

  // Glowing rim (Fresnel Simulation)
  const glow = new THREE.Mesh(
    new THREE.SphereGeometry(EARTH_RADIUS * 1.05, 64, 64),
    new THREE.MeshStandardMaterial({
      color: 0x60a5fa,
      transparent: true,
      opacity: 0.05,
      side: THREE.DoubleSide,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    })
  )
  scene.add(glow)

  let borders = null

  // Push borders out to radius ~101.25 (outside the grid) to ensure visibility
  // Calculation: 6371 - (-10 * 8) = 6451. 6451/6371 * 100 = 101.25
  const BORDER_DEPTH_OFFSET = -12;

  fetch('/countries.geojson')
    .then(r => r.json())
    .then(data => {
      // Points represent the geographical point in THREE space
      const points: number[] = []

      const addPoints = (coords: number[][]) => {
        for (let i = 0; i < coords.length - 1; i++) {
            // GeoJSON is [Lon, Lat]
            // Math util takes (Lat, Lon, Depth)
            const p1 = getPositionFromLatLonDepth(coords[i][1], coords[i][0], BORDER_DEPTH_OFFSET);
            const p2 = getPositionFromLatLonDepth(coords[i+1][1], coords[i+1][0], BORDER_DEPTH_OFFSET);

            points.push(p1.x, p1.y, p1.z);
            points.push(p2.x, p2.y, p2.z);
        }
      };

      data.features.forEach((feature: any) => {
        if (feature.geometry.type === 'Polygon') {
          feature.geometry.coordinates.forEach((coords: number[][]) => addPoints(coords));
        } else if (feature.geometry.type === 'MultiPolygon') {
          feature.geometry.coordinates.forEach((polygon: number[][][]) => {
            polygon.forEach(coords => addPoints(coords));
          });
        }
      });

      const bordersGeometry = new THREE.BufferGeometry()
      bordersGeometry.setAttribute('position', new THREE.Float32BufferAttribute(points, 3))

      borders = new THREE.LineSegments(
        bordersGeometry,
        new THREE.LineBasicMaterial({
          opacity: 1.0,
          transparent: true,
          color: 0x6586b5,
        })
      )
      scene.add(borders)
    })


  const renderer = new THREE.WebGLRenderer({
    canvas,
    antialias: true,
  })
  renderer.toneMapping = THREE.ACESFilmicToneMapping
  renderer.setSize(sizes.width, sizes.height)
  renderer.setPixelRatio(sizes.pixelRatio)

  const environment = new RoomEnvironment();
  const pmremGenerator = new THREE.PMREMGenerator(renderer);
  scene.background = new THREE.Color( 0x000000 );
  scene.environment = pmremGenerator.fromScene(environment, 0.2).texture;

  const resize = () => {
    sizes.width = window.innerWidth
    sizes.height = window.innerHeight
    sizes.pixelRatio = Math.min(window.devicePixelRatio, 2)

    renderer.setSize(sizes.width, sizes.height)
    renderer.setPixelRatio(sizes.pixelRatio)

    camera.aspect = sizes.width / sizes.height
    camera.updateProjectionMatrix()
  }

  window.addEventListener('resize', debounce(resize, 500))

  const mouse = new THREE.Vector2()
  window.addEventListener('mousemove', e => {
    mouse.x = e.clientX / sizes.width * 2 - 1
    mouse.y = - (e.clientY / sizes.height) * 2 + 1
  })

  const tick = () => {

    if (borders) {
      borders.material.color.set(0x6586b5)
      const raycaster = new THREE.Raycaster()
      raycaster.setFromCamera(mouse, camera)
      const intersectectedBorders = raycaster.intersectObjects([borders])
      for (const intersection of intersectectedBorders) {
        intersection.object.material.color.set(0xff0000)
      }
    }

    controls.update()
    renderer.render(scene, camera)

    window.requestAnimationFrame(tick)
  }

  tick()
</script>